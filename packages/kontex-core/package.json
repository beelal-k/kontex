{
  "name": "kontex-core",
  "version": "1.0.0",
  "description": "Core engine for kontex — quality gate, MCP server, compilation, embedding, storage, hooks, auth",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArekBee/kontex.git",
    "directory": "packages/kontex-core"
  },
  "homepage": "https://github.com/ArekBee/kontex#readme",
  "bugs": {
    "url": "https://github.com/ArekBee/kontex/issues"
  },
  "keywords": [
    "kontex",
    "mcp",
    "ai",
    "memory",
    "context",
    "llm",
    "model-context-protocol",
    "coding-assistant"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --packages external",
    "test": "bun test",
    "dev": "bun --watch src/index.ts",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.3.0",
    "@xenova/transformers": "^2.17.0",
    "ai": "^4.1.0",
    "@ai-sdk/openai": "^1.2.0",
    "@octokit/auth-oauth-device": "^7.1.0",
    "keytar": "^7.9.0",
    "gray-matter": "^4.0.3",
    "tiktoken": "^1.0.18",
    "sqlite-vec": "^0.1.6"
  },
  "devDependencies": {
    "bun-types": "^1.1.0",
    "typescript": "^5.7.0"
  }
}
